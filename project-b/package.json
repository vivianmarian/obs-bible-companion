{
  "name": "obs-bible-companion",
  "version": "0.1.0",
  "description": "Bitfocus Companion module for OBS Bible Plugin",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules ../node_modules/jest/bin/jest.js --config jest.config.js --coverage",
    "generate:metadata": "node --import=tsx/esm src/metadata/MetadataGenerator.ts",
    "start:relay": "node --import=tsx/esm src/bridge/RelayServer.ts"
  },
  "dependencies": {
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.0.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.10",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  }
}